{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.qariai.app" }],
      "destination": "https://qariai.app/:path*",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/screenshots/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/logo.png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ],
  "rewrites": [
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/ar", "destination": "/ar.html" },
    { "source": "/qaef", "destination": "/qaef.html" },
    { "source": "/how-qari-ai-works", "destination": "/how-qari-ai-works.html" },
    { "source": "/tajweed-mistakes-checker", "destination": "/tajweed-mistakes-checker.html" },
    { "source": "/best-ai-quran-app", "destination": "/best-ai-quran-app.html" },
    { "source": "/apps-like-tarteel", "destination": "/apps-like-tarteel.html" },
    { "source": "/learn/common-tajweed-mistakes", "destination": "/common-tajweed-mistakes.html" },
    { "source": "/learn/pronounce-ayn", "destination": "/pronounce-ayn.html" },
    { "source": "/learn/qalqalah-explained", "destination": "/qalqalah-explained.html" },
    { "source": "/compare/qari-ai-vs-tarteel", "destination": "/qari-ai-vs-tarteel.html" },
    { "source": "/compare/qari-ai-vs-tajweedmate", "destination": "/qari-ai-vs-tajweedmate.html" },
    { "source": "/open-methodology", "destination": "/open-methodology.html" },
    { "source": "/tajweed-rules", "destination": "/tajweed-rules.html" },
    { "source": "/tajweed-app-evaluation", "destination": "/tajweed-app-evaluation.html" },
    { "source": "/ai-quran-education-2026", "destination": "/ai-quran-education-2026.html" },
    { "source": "/teachers-guide-ai-tajweed", "destination": "/teachers-guide-ai-tajweed.html" },
    { "source": "/ar/tajweed-rules", "destination": "/ar/tajweed-rules.html" },
    { "source": "/ar/tajweed-mistakes", "destination": "/ar/tajweed-mistakes.html" },
    { "source": "/ar/how-qari-ai-works", "destination": "/ar/how-qari-ai-works.html" },
    { "source": "/maqamat-quran-guide", "destination": "/maqamat-quran-guide.html" },
    { "source": "/al-nabr-tajweed", "destination": "/al-nabr-tajweed.html" },
    { "source": "/ar/al-nabr", "destination": "/ar/al-nabr.html" },
    { "source": "/quran-app-comparison-2026", "destination": "/quran-app-comparison-2026.html" },
    { "source": "/.well-known/security.txt", "destination": "/.well-known/security.txt" },
    { "source": "/fr", "destination": "/fr.html" },
    { "source": "/ms", "destination": "/ms.html" },
    { "source": "/challenge", "destination": "/challenge.html" }
  ]
}
